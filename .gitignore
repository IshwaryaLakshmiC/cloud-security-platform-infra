# Terraform state — never commit
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Real variable values — never commit
terraform.tfvars
*.tfvars
!*.tfvars.example

# Crash logs
crash.log
crash.*.log

# Sensitive outputs
*.pem
*.key
.env

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
